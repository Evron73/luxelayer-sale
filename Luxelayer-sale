<script>
// LANG
function setLang(lang){
  document.querySelectorAll('.en').forEach(el=>el.style.display=lang==='en'?'':'none');
  document.querySelectorAll('.hu').forEach(el=>el.style.display=lang==='hu'?'':'none');
  document.querySelectorAll('.lang-btn').forEach((btn,i)=>{
    btn.classList.toggle('active',(lang==='en'&&i===0)||(lang==='hu'&&i===1));
  });
}

// UPLOADS
let personB64=null,productB64=null;
function setupUpload(inputId,zoneId,setter){
  document.getElementById(inputId).addEventListener('change',function(e){
    const file=e.target.files[0];if(!file)return;
    const reader=new FileReader();
    reader.onload=ev=>{
      const src=ev.target.result;
      setter(src.split(',')[1]);
      const zone=document.getElementById(zoneId);
      zone.classList.add('has-img');
      zone.innerHTML=`<img src="${src}" alt=""><div class="dz-overlay"><span>CHANGE</span></div>`;
    };
    reader.readAsDataURL(file);
  });
}
setupUpload('dPersonUpload','dPersonZone',v=>personB64=v);
setupUpload('dProductUpload','dProductZone',v=>productB64=v);

// DEMO
async function runDemo(){
  const productName=document.getElementById('dProductName').value.trim();
  if(!personB64){alert('Please upload your photo first.');return;}
  const btn=document.getElementById('dAnalyzeBtn');
  btn.disabled=true;
  document.getElementById('dEmpty').style.display='none';
  document.getElementById('dResults').classList.remove('show');
  ['dCard1','dCard2','dCard3'].forEach(id=>document.getElementById(id).classList.remove('show'));
  const loading=document.getElementById('dLoading');
  loading.classList.add('show');
  const msgs=['READING STYLE PROFILE...','ANALYZING COLOR PALETTE...','MATCHING PRODUCT...','CALCULATING SCORE...'];
  let mi=0;
  const t=setInterval(()=>{document.getElementById('dLoadMsg').textContent=msgs[++mi%msgs.length];},1100);
  try{
    const contentArr=[{type:"image",source:{type:"base64",media_type:"image/jpeg",data:personB64}}];
    if(productB64)contentArr.push({type:"image",source:{type:"base64",media_type:"image/jpeg",data:productB64}});
    const productDesc=productName?`The product: "${productName}".`:'Analyze general style.';
    if(productB64)contentArr.push({type:"text",text:"The second image is the outfit/product."});
    contentArr.push({type:"text",text:`You are FitMirror, an expert AI fashion stylist. Analyze the person's style and how well the product matches them.\n\n${productDesc}\n\nRespond ONLY with valid JSON, no markdown:\n{\n  "match_score": <0-100>,\n  "verdict": "<short verdict, max 5 words>",\n  "style_analysis": "<2 sentences about person's style>",\n  "pros": ["<pro1>","<pro2>","<pro3>"],\n  "tip": "<1 styling tip>"\n}`});
    const res=await fetch("https://api.anthropic.com/v1/messages",{
      method:"POST",
      headers:{"Content-Type":"application/json"},
      body:JSON.stringify({model:"claude-sonnet-4-6",max_tokens:1000,messages:[{role:"user",content:contentArr}]})
    });
    clearInterval(t);
    const data=await res.json();
    if(data.error)throw new Error(data.error.message);
    const r=JSON.parse(data.content[0].text.replace(/```json|```/g,'').trim());
    showResults(r);
  }catch(err){
    clearInterval(t);
    document.getElementById('dEmpty').style.display='flex';
    document.getElementById('dEmpty').innerHTML=`<div class="big-icon">⚠️</div><div style="color:#555">Error: ${err.message}</div>`;
  }finally{
    loading.classList.remove('show');
    btn.disabled=false;
  }
}

function showResults(r){
  const score=Math.min(100,Math.max(0,r.match_score||0));
  const fill=document.getElementById('dRingFill');
  const numEl=document.getElementById('dRingNum');
  fill.style.stroke=score>=75?'#4caf7d':score>=50?'#c9a84c':'#e05a4e';
  const circ=226;
  setTimeout(()=>{
    fill.style.strokeDashoffset=circ-(score/100)*circ;
    let c=0;const inc=setInterval(()=>{c=Math.min(score,c+2);numEl.textContent=c;if(c>=score)clearInterval(inc);},18);
  },100);
  document.getElementById('dVerdict').textContent=r.verdict||'Style Score';
  document.getElementById('dSubtitle').textContent=score>=75?'Great match for your style':score>=50?'Could work with right styling':'May not be your best match';
  document.getElementById('dStyleText').textContent=r.style_analysis||'';
  const prosEl=document.getElementById('dPros');
  prosEl.innerHTML='';
  (r.pros||[]).forEach(p=>{const t=document.createElement('span');t.className='result-tag';t.textContent=p;prosEl.appendChild(t);});
  document.getElementById('dCon').textContent=r.tip||'';
  document.getElementById('dResults').classList.add('show');
  ['dCard1','dCard2','dCard3'].forEach((id,i)=>{setTimeout(()=>document.getElementById(id).classList.add('show'),150+i*120);});
}
</script>
</body>
