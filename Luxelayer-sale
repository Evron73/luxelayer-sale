<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LuxeLayer + FitMirror — AI Fashion App For Sale</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=Outfit:wght@300;400;500;600&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
:root {
  --black: #080808;
  --white: #fafaf7;
  --cream: #f2ede3;
  --gold: #c9a84c;
  --gold-light: #e8cc7a;
  --gold-dim: rgba(201,168,76,0.12);
  --muted: #8a8070;
  --border: #e0d8cc;
  --dark: #141410;
  --surface: #1e1e18;
  --text-dim: #888;
}

*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{font-family:'Outfit',sans-serif;background:var(--black);color:var(--white);overflow-x:hidden;}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:100;padding:0 48px;height:64px;display:flex;align-items:center;justify-content:space-between;background:rgba(8,8,8,0.92);backdrop-filter:blur(16px);border-bottom:1px solid rgba(201,168,76,0.15);}
.nav-logo{font-family:'Playfair Display',serif;font-weight:900;font-size:18px;letter-spacing:-0.3px;display:flex;align-items:center;gap:10px;color:var(--white);}
.nav-logo .sep{color:var(--gold);font-style:italic;margin:0 4px;}
.nav-badge{font-family:'Space Mono',monospace;font-size:9px;letter-spacing:2px;text-transform:uppercase;background:var(--gold);color:var(--black);padding:3px 10px;font-weight:700;}
.nav-right{display:flex;align-items:center;gap:20px;}
.lang-toggle{display:flex;gap:2px;border:1px solid rgba(201,168,76,0.3);border-radius:3px;overflow:hidden;}
.lang-btn{padding:5px 12px;font-size:10px;font-weight:700;letter-spacing:0.1em;cursor:pointer;border:none;background:transparent;color:var(--muted);transition:all 0.2s;font-family:'Space Mono',monospace;}
.lang-btn.active{background:var(--gold);color:var(--black);}
.nav-cta{background:var(--gold);color:var(--black);font-size:12px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;padding:10px 24px;text-decoration:none;transition:background 0.2s;}
.nav-cta:hover{background:var(--gold-light);}

/* HERO */
.hero{min-height:100vh;display:grid;grid-template-columns:1fr 1fr;padding-top:64px;position:relative;overflow:hidden;}
.hero-left{background:var(--black);padding:80px 60px;display:flex;flex-direction:column;justify-content:center;position:relative;}
.hero-left::after{content:'';position:absolute;right:-40px;top:0;bottom:0;width:80px;background:var(--black);clip-path:polygon(0 0,0% 100%,100% 100%);z-index:2;}
.hero-eyebrow{display:inline-flex;align-items:center;gap:10px;font-family:'Space Mono',monospace;font-size:10px;letter-spacing:3px;text-transform:uppercase;color:var(--gold);margin-bottom:28px;}
.hero-eyebrow::before{content:'';width:24px;height:1px;background:var(--gold);}
.hero-h1{font-family:'Playfair Display',serif;font-weight:900;font-size:clamp(44px,5vw,76px);line-height:1.0;color:var(--white);margin-bottom:24px;letter-spacing:-1px;}
.hero-h1 em{font-style:italic;color:var(--gold);}
.hero-sub{font-size:16px;line-height:1.7;color:var(--text-dim);font-weight:300;max-width:420px;margin-bottom:36px;}
.hero-price{display:inline-flex;flex-direction:column;gap:4px;border:1px solid rgba(201,168,76,0.35);padding:20px 36px;margin-bottom:32px;align-self:flex-start;}
.price-label{font-family:'Space Mono',monospace;font-size:9px;letter-spacing:3px;text-transform:uppercase;color:var(--muted);}
.price-value{font-family:'Playfair Display',serif;font-size:40px;font-weight:900;color:var(--gold);letter-spacing:-1px;line-height:1;}
.price-note{font-size:11px;color:var(--muted);}
.hero-btns{display:flex;gap:12px;flex-wrap:wrap;}
.btn-primary{padding:14px 32px;background:var(--gold);color:var(--black);border:none;font-family:'Outfit',sans-serif;font-size:13px;font-weight:600;cursor:pointer;text-decoration:none;display:inline-block;transition:all 0.2s;letter-spacing:0.5px;}
.btn-primary:hover{background:var(--gold-light);transform:translateY(-1px);}
.btn-ghost{padding:14px 32px;background:transparent;color:var(--text-dim);border:1px solid #333;font-family:'Outfit',sans-serif;font-size:13px;cursor:pointer;text-decoration:none;display:inline-block;transition:all 0.2s;}
.btn-ghost:hover{border-color:var(--gold);color:var(--gold);}
.hero-metrics{display:flex;gap:36px;margin-top:48px;padding-top:36px;border-top:1px solid #222;}
.metric-val{font-family:'Playfair Display',serif;font-size:32px;font-weight:700;color:var(--white);line-height:1;margin-bottom:4px;}
.metric-val span{color:var(--gold);}
.metric-lbl{font-size:11px;color:#555;font-family:'Space Mono',monospace;letter-spacing:0.5px;}

/* HERO RIGHT — fashion collage */
.hero-right{background:#111;position:relative;overflow:hidden;display:grid;grid-template-rows:1fr 1fr;grid-template-columns:1fr 1fr;}
.fashion-cell{overflow:hidden;position:relative;}
.fashion-cell img{width:100%;height:100%;object-fit:cover;filter:grayscale(20%) contrast(1.05);transition:transform 0.6s;}
.fashion-cell:hover img{transform:scale(1.04);}
.fashion-cell::after{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(201,168,76,0.08),transparent);}
.fashion-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(8,8,8,0.6),transparent);display:flex;align-items:flex-end;padding:20px;}
.fashion-tag{font-family:'Space Mono',monospace;font-size:9px;letter-spacing:2px;text-transform:uppercase;color:var(--gold);background:rgba(0,0,0,0.7);padding:4px 10px;}
.hero-badge{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);z-index:10;text-align:center;background:rgba(8,8,8,0.85);border:1px solid rgba(201,168,76,0.5);padding:24px 32px;backdrop-filter:blur(8px);}
.hero-badge-title{font-family:'Playfair Display',serif;font-size:13px;font-weight:700;color:var(--gold);letter-spacing:0.1em;margin-bottom:6px;}
.hero-badge-score{font-family:'Playfair Display',serif;font-size:52px;font-weight:900;color:var(--white);line-height:1;}
.hero-badge-sub{font-size:10px;color:var(--muted);letter-spacing:2px;text-transform:uppercase;margin-top:4px;font-family:'Space Mono',monospace;}

/* FASHION STRIP */
.fashion-strip{display:grid;grid-template-columns:repeat(5,1fr);height:280px;overflow:hidden;}
.strip-cell{position:relative;overflow:hidden;}
.strip-cell img{width:100%;height:100%;object-fit:cover;filter:grayscale(15%);transition:transform 0.5s,filter 0.5s;}
.strip-cell:hover img{transform:scale(1.06);filter:grayscale(0%);}
.strip-cell-overlay{position:absolute;inset:0;background:linear-gradient(to bottom,transparent 40%,rgba(8,8,8,0.7));display:flex;align-items:flex-end;padding:16px;opacity:0;transition:opacity 0.3s;}
.strip-cell:hover .strip-cell-overlay{opacity:1;}
.strip-cell-label{font-family:'Space Mono',monospace;font-size:9px;letter-spacing:2px;color:var(--gold);}
.strip-gold-bar{height:2px;background:linear-gradient(to right,transparent,var(--gold),transparent);}

/* SECTION BASE */
.section{padding:100px 80px;max-width:1200px;margin:0 auto;}
.section-eyebrow{font-family:'Space Mono',monospace;font-size:10px;letter-spacing:3px;text-transform:uppercase;color:var(--gold);margin-bottom:16px;}
.section-title{font-family:'Playfair Display',serif;font-size:clamp(32px,4vw,56px);font-weight:900;line-height:1.05;letter-spacing:-1px;margin-bottom:48px;}
.section-title em{font-style:italic;color:var(--gold);}
.divider{height:1px;background:linear-gradient(to right,transparent,rgba(201,168,76,0.25),transparent);}

/* STATS */
.stats-grid{display:grid;grid-template-columns:repeat(6,1fr);gap:1px;background:rgba(201,168,76,0.1);border:1px solid rgba(201,168,76,0.1);}
.stat-item{background:var(--surface);padding:32px 24px;}
.stat-num{font-family:'Playfair Display',serif;font-size:38px;font-weight:900;color:var(--gold);line-height:1;margin-bottom:8px;}
.stat-lbl{font-size:12px;color:var(--text-dim);font-weight:300;line-height:1.4;}

/* PRODUCTS */
.products-grid{display:grid;grid-template-columns:1fr 1fr;gap:2px;}
.product-card{background:var(--surface);padding:48px;position:relative;overflow:hidden;}
.product-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(to right,transparent,var(--gold),transparent);opacity:0.5;}
.product-num{font-family:'Space Mono',monospace;font-size:11px;letter-spacing:2px;color:var(--muted);margin-bottom:20px;}
.product-name{font-family:'Playfair Display',serif;font-size:32px;font-weight:900;margin-bottom:12px;line-height:1.1;}
.product-name em{font-style:italic;color:var(--gold);}
.product-desc{font-size:15px;color:var(--text-dim);font-weight:300;line-height:1.7;margin-bottom:32px;}
.product-tags{display:flex;flex-wrap:wrap;gap:8px;}
.tag{font-family:'Space Mono',monospace;font-size:9px;letter-spacing:1.5px;text-transform:uppercase;padding:5px 12px;border:1px solid rgba(201,168,76,0.25);color:var(--muted);}

/* DEMO SECTION */
.demo-section{background:#0d0d0a;padding:80px;}
.demo-inner{max-width:1100px;margin:0 auto;}
.demo-grid{display:grid;grid-template-columns:1fr 1fr;gap:48px;margin-top:48px;align-items:start;}
.upload-zone{border:1px dashed #333;aspect-ratio:4/3;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:12px;cursor:pointer;transition:border-color 0.2s;background:#111;position:relative;overflow:hidden;}
.upload-zone:hover{border-color:var(--gold);}
.upload-zone.has-img{border-style:solid;border-color:rgba(201,168,76,0.4);}
.upload-zone img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;}
.upload-zone .dz-overlay{position:absolute;inset:0;background:rgba(0,0,0,0.5);display:flex;align-items:center;justify-content:center;opacity:0;transition:opacity 0.2s;}
.upload-zone:hover .dz-overlay{opacity:1;}
.upload-zone .dz-overlay span{font-family:'Space Mono',monospace;font-size:11px;letter-spacing:2px;color:var(--gold);}
.upload-icon{font-size:32px;opacity:0.3;}
.upload-label{font-size:13px;color:var(--text-dim);font-weight:300;}
.upload-sub{font-size:11px;color:#444;font-family:'Space Mono',monospace;letter-spacing:1px;}
.upload-zones{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
.zone-label{font-family:'Space Mono',monospace;font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-bottom:8px;}
.demo-input{width:100%;background:#111;border:1px solid #222;color:var(--white);padding:12px 16px;font-family:'Outfit',sans-serif;font-size:14px;margin-bottom:16px;transition:border-color 0.2s;}
.demo-input:focus{outline:none;border-color:var(--gold);}
.demo-input::placeholder{color:#444;}
.analyze-btn{width:100%;padding:16px;background:var(--gold);color:var(--black);border:none;font-family:'Outfit',sans-serif;font-size:14px;font-weight:600;cursor:pointer;letter-spacing:0.5px;transition:background 0.2s;}
.analyze-btn:hover{background:var(--gold-light);}
.analyze-btn:disabled{opacity:0.5;cursor:not-allowed;}
.demo-result{background:#111;border:1px solid #222;min-height:300px;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:32px;gap:16px;}
.demo-empty{text-align:center;}
.demo-empty .big-icon{font-size:48px;opacity:0.2;margin-bottom:12px;}
.demo-empty p{font-size:14px;color:#444;font-weight:300;}
.loading-state{display:none;flex-direction:column;align-items:center;gap:12px;}
.loading-state.show{display:flex;}
.loading-ring{width:48px;height:48px;border:2px solid #222;border-top-color:var(--gold);border-radius:50%;animation:spin 0.8s linear infinite;}
@keyframes spin{to{transform:rotate(360deg);}}
.load-msg{font-family:'Space Mono',monospace;font-size:10px;letter-spacing:2px;color:var(--gold);}
.result-panel{display:none;width:100%;}
.result-panel.show{display:block;}
.score-ring-wrap{text-align:center;margin-bottom:20px;}
.score-ring-wrap svg{width:100px;height:100px;}
.score-circle-bg{fill:none;stroke:#222;stroke-width:8;}
.score-circle-fill{fill:none;stroke:var(--gold);stroke-width:8;stroke-linecap:round;stroke-dasharray:226;stroke-dashoffset:226;transform:rotate(-90deg);transform-origin:50% 50%;transition:stroke-dashoffset 1.2s ease;}
.score-num{font-family:'Playfair Display',serif;font-size:28px;font-weight:900;fill:var(--white);}
.result-verdict{font-family:'Playfair Display',serif;font-size:18px;font-weight:700;text-align:center;margin-bottom:4px;}
.result-sub{font-size:12px;color:var(--muted);text-align:center;margin-bottom:16px;font-family:'Space Mono',monospace;letter-spacing:1px;}
.result-style{font-size:13px;color:var(--text-dim);line-height:1.6;text-align:center;margin-bottom:16px;font-weight:300;}
.result-tags{display:flex;flex-wrap:wrap;gap:6px;justify-content:center;margin-bottom:12px;}
.result-tag{font-size:11px;padding:4px 12px;background:rgba(77,175,107,0.15);border:1px solid rgba(77,175,107,0.3);color:#4caf7d;}
.result-tip{font-size:12px;color:var(--muted);text-align:center;padding:12px;border:1px solid #222;font-style:italic;}
.r-card{opacity:0;transform:translateY(10px);transition:all 0.3s;}
.r-card.show{opacity:1;transform:translateY(0);}

/* CHECKLIST */
.checklist{display:grid;grid-template-columns:repeat(3,1fr);gap:2px;background:rgba(201,168,76,0.08);}
.check-item{background:var(--surface);padding:28px 32px;display:flex;gap:16px;border-left:2px solid transparent;transition:border-color 0.2s;}
.check-item:hover{border-left-color:var(--gold);}
.check-mark{color:var(--gold);font-size:14px;flex-shrink:0;margin-top:2px;}
.check-text strong{display:block;font-size:14px;font-weight:500;color:var(--white);margin-bottom:4px;}
.check-text span{font-size:13px;color:var(--text-dim);font-weight:300;line-height:1.5;}

/* PRICE SECTION */
.price-section{background:#0d0d0a;padding:100px 80px;text-align:center;}
.price-box{display:inline-flex;flex-direction:column;align-items:center;gap:8px;border:1px solid rgba(201,168,76,0.35);padding:48px 80px;margin:40px 0;}
.price-box-label{font-family:'Space Mono',monospace;font-size:10px;letter-spacing:3px;text-transform:uppercase;color:var(--muted);}
.price-box-value{font-family:'Playfair Display',serif;font-size:72px;font-weight:900;color:var(--gold);line-height:1;letter-spacing:-2px;}
.price-box-note{font-size:14px;color:var(--muted);}
.price-includes{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;max-width:900px;margin:40px auto 0;text-align:left;}
.pi-item{display:flex;gap:12px;align-items:flex-start;padding:20px 24px;background:var(--surface);border:1px solid rgba(201,168,76,0.08);}
.pi-mark{color:var(--gold);flex-shrink:0;margin-top:2px;}
.pi-text{font-size:13px;color:var(--text-dim);font-weight:300;line-height:1.5;}
.pi-text strong{display:block;color:var(--white);font-weight:500;margin-bottom:2px;}

/* CONTACT */
.contact-section{padding:100px 80px;display:grid;grid-template-columns:1fr 1fr;gap:80px;max-width:1200px;margin:0 auto;align-items:center;}
.contact-email-link{font-family:'Playfair Display',serif;font-size:clamp(22px,3vw,36px);font-weight:700;color:var(--gold);text-decoration:none;display:block;margin:24px 0;transition:color 0.2s;}
.contact-email-link:hover{color:var(--gold-light);}
.contact-note{font-size:15px;color:var(--text-dim);font-weight:300;line-height:1.7;margin-bottom:32px;}
.contact-visual{position:relative;aspect-ratio:4/5;overflow:hidden;}
.contact-visual img{width:100%;height:100%;object-fit:cover;filter:grayscale(20%);}
.contact-visual::after{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(201,168,76,0.1),transparent);}

/* FOOTER */
footer{border-top:1px solid rgba(201,168,76,0.1);padding:32px 80px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:16px;}
.footer-logo{font-family:'Playfair Display',serif;font-size:16px;font-weight:700;color:var(--muted);letter-spacing:0.05em;}
.footer-note{font-size:11px;color:#444;font-family:'Space Mono',monospace;letter-spacing:0.5px;}

/* LANG */
.hu{display:none;}

/* RESPONSIVE */
@media(max-width:900px){
  nav{padding:0 20px;}
  .nav-badge{display:none;}
  .hero{grid-template-columns:1fr;}
  .hero-right{height:300px;}
  .hero-left::after{display:none;}
  .section{padding:60px 24px;}
  .stats-grid{grid-template-columns:repeat(3,1fr);}
  .products-grid{grid-template-columns:1fr;}
  .demo-section{padding:60px 24px;}
  .demo-grid{grid-template-columns:1fr;}
  .checklist{grid-template-columns:1fr;}
  .price-section{padding:60px 24px;}
  .price-includes{grid-template-columns:1fr;}
  .contact-section{grid-template-columns:1fr;padding:60px 24px;}
  .contact-visual{display:none;}
  .fashion-strip{grid-template-columns:repeat(3,1fr);}
  footer{padding:24px 20px;flex-direction:column;text-align:center;}
}
</style>
</head>
